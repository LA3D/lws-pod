# Copy to .env.local and adjust. The make targets read it via --env-file .env.local.
JSS_VERSION=0.0.209
JSS_HOST_PORT=3838

# LOCAL-DEV ONLY. Relax the LWS-CID WebID-fetch SSRF private-IP guard so the self-signed
# LWS-CID auth round-trip can be exercised against a local pod (see Dockerfile). Default off
# to keep the committed image pristine. Note: the http local pod still can't reach the CID
# path (the verifier also requires an https kid) — the actual proof runs on the TLS pod
# (make up-tls / make cid-tls), which patches regardless. NEVER set true for a public build.
PATCH_CID_PRIVATE_IPS=false
